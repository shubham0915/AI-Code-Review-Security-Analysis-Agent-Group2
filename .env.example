# ─────────────────────────────────────────────
# Environment Configuration
# Copy this to .env and fill in your values.
# ALL values default to local/open-source — no paid APIs needed.
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-me-to-a-random-64-char-string
LOG_LEVEL=INFO

# ── Ollama (local LLM) ───────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=codestral          # Code Analysis + Security + Remediation
OLLAMA_FAST_MODEL=qwen2.5-coder:7b     # PR Summary + fast tasks
OLLAMA_EMBED_MODEL=nomic-embed-text    # Embeddings
OLLAMA_TIMEOUT=120                      # seconds

# ── ChromaDB ─────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_OWASP_COLLECTION=owasp_knowledge_base
CHROMA_PATTERNS_COLLECTION=code_patterns
CHROMA_REMEDIATION_COLLECTION=remediation_guides

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_ANALYSIS=3600          # 1 hour
REDIS_CACHE_TTL_EMBEDDING=86400        # 24 hours
REDIS_CACHE_TTL_LLM=3600              # 1 hour
REDIS_SESSION_TTL=1800                 # 30 minutes

# ── Celery ───────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=2

# ── Code Submission Limits ───────────────────
MAX_CODE_LINES=10000
MAX_FILE_SIZE_MB=5
ALLOWED_EXTENSIONS=.py,.java

# ── JWT Authentication ───────────────────────
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Data Retention ───────────────────────────
ANALYSIS_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7

# ── Monitoring ───────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
PHOENIX_PORT=6006
